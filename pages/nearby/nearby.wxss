.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 20rpx;
}
.tabs {
  display: flex;
  overflow-x: auto;
  white-space: nowrap;
  background-color: white;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 10rpx;
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.tabs::-webkit-scrollbar {
  display: none;
}
.tab {
  flex-shrink: 0;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
  color: #666;
  border-radius: 40rpx;
  background-color: #f5f5f5;
  margin-right: 16rpx;
}
.tab.active {
  background-color: #07c160;
  color: white;
}
.list {
  background-color: white;
  border-radius: 16rpx;
  padding: 20rpx;
}
.item {
  background-color: white;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
  width: 100% !important;
  box-sizing: border-box;
  word-wrap: break-word;
  word-break: break-word;
}
.item:last-child {
  margin-bottom: 0;
}
.name {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  width: 100%;
  word-wrap: break-word;
  word-break: break-word;
  overflow-wrap: break-word;
}
.address {
  font-size: 26rpx;
  color: #888;
  margin-top: 8rpx;
  display: block;
  width: 100%;
  word-wrap: break-word;
  word-break: break-word;
}
.distance {
  font-size: 24rpx;
  color: #aaa;
  margin-top: 8rpx;
  display: block;
}
.loading, .empty {
  text-align: center;
  padding: 60rpx;
  color: #999;
}
.list {
  background-color: white;
  border-radius: 16rpx;
  padding: 20rpx;
  width: 100%;
  box-sizing: border-box;
}