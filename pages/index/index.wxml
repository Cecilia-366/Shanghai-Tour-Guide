<!-- 搜索框 -->
<view style="background-color: #fff; padding: 20rpx; border-bottom: 1rpx solid #eee;">
  <input placeholder="搜索景点名称" bindinput="onSearchInput" style="background-color: #f5f5f5; border-radius: 40rpx; padding: 20rpx 30rpx; font-size: 28rpx;" />
</view>

<!-- 标签栏：水平滚动 -->
<view style="display: flex; overflow-x: auto; white-space: nowrap; padding: 20rpx; background-color: #fff; margin-bottom: 10rpx;">
  <view wx:for="{{tags}}" wx:key="index" bindtap="filterByTag" data-tag="{{item}}" style="display: inline-block; margin-right: 20rpx; padding: 12rpx 32rpx; background-color: {{currentTag === item ? '#07c160' : '#f0f0f0'}}; border-radius: 40rpx; color: {{currentTag === item ? '#fff' : '#333'}}; font-size: 28rpx;">
    {{item}}
  </view>
</view>

<!-- 景点列表（你原来的美化版） -->
<view style="background-color: #f5f5f5; min-height: 100vh; padding: 20rpx 0;">
  <view wx:for="{{spots}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}" data-spot="{{item}}" style="background-color: white; margin: 16rpx 24rpx; border-radius: 24rpx; padding: 30rpx; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);">
    <view style="flex: 1;">
      <text style="font-size: 36rpx; font-weight: bold; color: #1a1a1a; display: block;">{{item.name}}</text>
      <text style="font-size: 28rpx; color: #888; margin-top: 12rpx; display: block;">{{item.intro}}</text>
    </view>
    <text style="font-size: 44rpx; color: #ccc;">〉</text>
  </view>
</view>